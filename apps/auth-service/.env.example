AUTH_SERVICE_GRPC_URL=0.0.0.0:50054
NODE_ENV=development

# PostgreSQL — same as packages/prisma/.env
POSTGRES_DATABASE_URL=postgresql://user:password@localhost:5432/nerve_db

# Redis
REDIS_URL=redis://localhost:6380

# RSA key pair (base64-encoded PEM)
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Encode:   base64 -w 0 private.pem && base64 -w 0 public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Token TTLs (seconds)
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800
